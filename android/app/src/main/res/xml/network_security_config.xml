<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Izinkan HTTP (cleartext) ke IP server lokal.
        Android 9+ memblokir HTTP secara default — file ini mengizinkannya
        khusus untuk IP 172.16.170.128 saja (lebih aman dari allow semua).
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">172.16.170.128</domain>
    </domain-config>

    <!-- Semua traffic lain tetap wajib HTTPS -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
